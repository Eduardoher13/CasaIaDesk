# ==========================================================================
# CasaIA Backend — Variables de entorno
# Copia este archivo a `.env` y ajusta los valores.
# Las variables marcadas [PROD] son obligatorias en producción.
# ==========================================================================

# --- Servidor -------------------------------------------------------------
# Puerto donde escucha la API. Muchos hosts (Railway/Render/Heroku) lo
# inyectan automáticamente; respeta el que te den.
PORT=8000

# Interfaz de red. 0.0.0.0 = acepta conexiones externas (necesario en la nube).
HOST=0.0.0.0

# development | production
# En producción activa validaciones de seguridad (ver más abajo).
NODE_ENV=development

# Orígenes permitidos para CORS, separados por coma.
# Vacío o "*" = permite cualquier origen (útil para apps móviles).
# Ejemplo web: CORS_ORIGIN=https://tuapp.com,https://www.tuapp.com
CORS_ORIGIN=

# --- Base de datos PostgreSQL ---------------------------------------------
# Elige UNA opción: (A) variables sueltas  o  (B) DATABASE_URL.

# Opción A — Docker local (npm run db:up), puerto 5433
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=casa_ia_desk

# Opción B — URL completa (Neon, Supabase, Railway, RDS, etc.) [PROD]
# Si DATABASE_URL está definida, tiene prioridad sobre las DB_* de arriba.
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Activa SSL para la conexión a la BD. Obligatorio con DigitalOcean/Render/Neon. [PROD]
# También se activa solo si DATABASE_URL incluye ?sslmode=require
DB_SSL=false

# --- TypeORM --------------------------------------------------------------
# true = TypeORM crea/altera tablas automáticamente desde las entidades.
# ⚠️ SOLO desarrollo (o el PRIMER arranque en prod). En producción ponlo en
# false para evitar cambios destructivos en el esquema.
DB_SYNCHRONIZE=true

# Loguea cada query SQL. Déjalo en false en producción.
DB_LOGGING=false

# --- Autenticación (JWT) --------------------------------------------------
# Secreto para firmar los tokens. Recomendado usar uno propio en producción
# (p. ej. `openssl rand -hex 32`). Si se deja el de desarrollo solo se muestra
# una advertencia; la app igual arranca.
JWT_SECRET=casaia-dev-secret

# Caducidad del token (ej. 7d, 24h, 3600s).
JWT_EXPIRES_IN=7d

# --- Integraciones externas -----------------------------------------------
# Google Directions API — para GET /deliveries/directions.
# Habilita "Directions API" en Google Cloud Console y restringe la key.
# Si se deja vacía, ese endpoint responde error y el frontend usa ruta recta.
GOOGLE_MAPS_API_KEY=
