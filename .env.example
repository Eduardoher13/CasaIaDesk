# Server
PORT=8000
NODE_ENV=development

# PostgreSQL — elige UNA opción:

# Opción A: Docker (npm run db:up) — puerto 5433 para no chocar con Postgres local
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=casa_ia_desk

# Opción B: Postgres local Homebrew (puerto 5432, usuario = tu usuario macOS)
# DB_PORT=5432
# DB_USERNAME=ken
# DB_PASSWORD=

# O usa una URL completa (Neon, Supabase, Railway, etc.)
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# DB_SSL=true

# TypeORM — solo desarrollo; en producción usar migraciones
DB_SYNCHRONIZE=true
DB_LOGGING=false
